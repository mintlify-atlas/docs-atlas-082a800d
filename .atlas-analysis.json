  "keyFeatures": [
    "Manager-worker architecture for distributed mirror synchronization",
    "Three sync providers: rsync, two-stage-rsync, and custom command",
    "HTTP/HTTPS API between manager and workers with optional TLS",
    "Multiple database backends: BoltDB, Badger, LevelDB, Redis",
    "cgroup v1/v2 support for resource limiting of sync jobs",
    "Docker container support for running mirror scripts in isolation",
    "Btrfs snapshot and ZFS snapshot hooks for atomic mirror updates",
    "Hot config reload via SIGHUP without stopping sync jobs",
    "tunasynctl CLI for live job control: start, stop, disable, restart, reload",
    "systemd service integration with journald-compatible logging"
  ],
  "publicApiSurface": [
    "GET /jobs — list all mirror jobs across all workers",
    "DELETE /jobs/disabled — flush all disabled jobs",
    "GET /workers — list all registered workers",
    "POST /workers — register a worker",
    "DELETE /workers/:id — remove a worker",
    "GET /workers/:id/jobs — list jobs for a specific worker",
    "POST /workers/:id/jobs/:job — update job status",
    "POST /workers/:id/jobs/:job/size — update mirror size",
    "POST /workers/:id/schedules — update job schedules",
    "POST /cmd — send control commands (start/stop/disable/restart/reload/ping)",
    "tunasync manager — start the manager server",
    "tunasync worker — start a worker process",
    "tunasynctl list — list mirror jobs",
    "tunasynctl workers — list workers",
    "tunasynctl start/stop/disable/restart — control mirror jobs",
    "tunasynctl reload — hot-reload worker configuration",
    "tunasynctl set-size — manually update mirror size",
    "tunasynctl rm-worker — remove a worker",
    "tunasynctl flush — flush disabled jobs"
  ]
}
